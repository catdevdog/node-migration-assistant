{
  "name": "node-migrator",
  "version": "0.1.0",
  "description": "Node.js 마이그레이션 자동화 도구 — 의존성 분석, 코드 변환, AI 기반 리팩토링",
  "type": "module",
  "bin": {
    "node-migrator": "./dist/server/bin/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch bin/cli.ts -- ./test-project --dev",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "npm run build && node dist/server/bin/cli.js ./test-project",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "express": "^5.1.0",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "glob": "^11.0.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@typescript-eslint/parser": "^8.30.1",
    "@typescript-eslint/typescript-estree": "^8.30.1",
    "recast": "^0.23.9",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "zustand": "^5.0.3",
    "@xyflow/react": "^12.6.0",
    "@monaco-editor/react": "^4.7.0",
    "react-resizable-panels": "^2.1.7",
    "lucide-react": "^0.475.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.5.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "vitest": "^3.1.1",
    "@types/semver": "^7.5.8"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
